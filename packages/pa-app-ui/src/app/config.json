{
  "$schema": "../schemas/app.schema.json",
  "id": "product-architect",
  "type": "app",
  "name": "Product Architect",
  "theme": "dark",
  "version": "1.0.0",
  "modules": [
    {
      "id": "graph-editor-module",
      "type": "module",
      "name": "Graph Editor",
      "icon": "network",
      "pages": [
        {
          "id": "canvas-page",
          "type": "page",
          "title": "Canvas",
          "template": "graph-editor",
          "overrides": {
            "sections.canvas.blocks[0].props.dataSource": "/api/graphs/default"
          }
        },
        {
          "id": "layers-page",
          "type": "page",
          "title": "Layers",
          "sections": [
            {
              "id": "main",
              "type": "section",
              "layout": "vertical",
              "blocks": [
                {
                  "id": "layer-manager",
                  "type": "layer-manager",
                  "props": {
                    "dataSource": "/api/graphs/default/layers"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "dashboard-module",
      "type": "module",
      "name": "Dashboard",
      "icon": "dashboard",
      "pages": [
        {
          "id": "overview-page",
          "type": "page",
          "title": "Overview",
          "template": "dashboard",
          "overrides": {
            "sections.metrics.blocks[0].props.dataSource": "/api/metrics/revenue",
            "sections.metrics.blocks[1].props.dataSource": "/api/metrics/users",
            "sections.metrics.blocks[2].props.dataSource": "/api/metrics/conversion",
            "sections.metrics.blocks[3].props.dataSource": "/api/metrics/aov"
          }
        }
      ]
    }
  ]
}

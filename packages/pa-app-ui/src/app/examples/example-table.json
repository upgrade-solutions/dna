{
  "id": "table-example",
  "type": "app",
  "name": "Data Table",
  "theme": "dark",
  "showModuleSidebar": false,
  "version": "1.0.0",
  "modules": [
    {
      "id": "data-module",
      "type": "module",
      "name": "Data",
      "icon": "table",
      "showNavigation": false,
      "pages": [
        {
          "id": "users-table-page",
          "type": "page",
          "title": "Users",
          "showHeader": false,
          "sections": [
            {
              "id": "table-header",
              "type": "section",
              "layout": "horizontal",
              "blocks": [
                {
                  "id": "page-title",
                  "type": "heading",
                  "props": {
                    "level": 2,
                    "text": "User Management"
                  }
                },
                {
                  "id": "add-user-btn",
                  "type": "button",
                  "props": {
                    "label": "Add User",
                    "icon": "+",
                    "variant": "primary"
                  }
                }
              ]
            },
            {
              "id": "filters-section",
              "type": "section",
              "layout": "horizontal",
              "blocks": [
                {
                  "id": "search-field",
                  "type": "text-field",
                  "props": {
                    "placeholder": "Search users...",
                    "icon": "🔍"
                  }
                },
                {
                  "id": "role-filter",
                  "type": "select",
                  "props": {
                    "label": "Role",
                    "options": ["All", "Admin", "Editor", "Viewer"]
                  }
                },
                {
                  "id": "status-filter",
                  "type": "select",
                  "props": {
                    "label": "Status",
                    "options": ["All", "Active", "Inactive"]
                  }
                }
              ]
            },
            {
              "id": "table-section",
              "type": "section",
              "layout": "flex",
              "blocks": [
                {
                  "id": "users-table",
                  "type": "data-table",
                  "props": {
                    "columns": [
                      { "key": "name", "label": "Name", "sortable": true },
                      { "key": "email", "label": "Email", "sortable": true },
                      { "key": "role", "label": "Role", "sortable": true },
                      { "key": "status", "label": "Status", "sortable": true },
                      { "key": "actions", "label": "Actions", "sortable": false }
                    ],
                    "data": [
                      {
                        "id": "1",
                        "name": "Alice Johnson",
                        "email": "alice@example.com",
                        "role": "Admin",
                        "status": "Active"
                      },
                      {
                        "id": "2",
                        "name": "Bob Smith",
                        "email": "bob@example.com",
                        "role": "Editor",
                        "status": "Active"
                      },
                      {
                        "id": "3",
                        "name": "Carol White",
                        "email": "carol@example.com",
                        "role": "Viewer",
                        "status": "Inactive"
                      }
                    ],
                    "pagination": {
                      "pageSize": 10,
                      "currentPage": 1,
                      "total": 3
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

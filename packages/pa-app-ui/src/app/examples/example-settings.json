{
  "id": "settings-example",
  "type": "app",
  "name": "Settings",
  "theme": "dark",
  "showModuleSidebar": false,
  "version": "1.0.0",
  "modules": [
    {
      "id": "settings-module",
      "type": "module",
      "name": "Settings",
      "icon": "gear",
      "showNavigation": false,
      "pages": [
        {
          "id": "general-settings",
          "type": "page",
          "title": "General",
          "showHeader": false,
          "sections": [
            {
              "id": "settings-sidebar",
              "type": "section",
              "layout": "vertical",
              "blocks": [
                {
                  "id": "sidebar-title",
                  "type": "heading",
                  "props": {
                    "level": 3,
                    "text": "Settings"
                  }
                },
                {
                  "id": "nav-general",
                  "type": "button",
                  "props": {
                    "label": "General",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "nav-appearance",
                  "type": "button",
                  "props": {
                    "label": "Appearance",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "nav-notifications",
                  "type": "button",
                  "props": {
                    "label": "Notifications",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "nav-privacy",
                  "type": "button",
                  "props": {
                    "label": "Privacy",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "nav-advanced",
                  "type": "button",
                  "props": {
                    "label": "Advanced",
                    "variant": "ghost"
                  }
                }
              ]
            },
            {
              "id": "settings-content",
              "type": "section",
              "layout": "vertical",
              "blocks": [
                {
                  "id": "content-title",
                  "type": "heading",
                  "props": {
                    "level": 2,
                    "text": "General Settings"
                  }
                },
                {
                  "id": "general-panel",
                  "type": "panel",
                  "props": {
                    "title": "Basic Information"
                  }
                },
                {
                  "id": "app-name",
                  "type": "text-field",
                  "props": {
                    "label": "Application Name",
                    "placeholder": "My Application",
                    "value": "Product Architect"
                  }
                },
                {
                  "id": "language",
                  "type": "select",
                  "props": {
                    "label": "Language",
                    "options": ["English", "Spanish", "French", "German"],
                    "value": "English"
                  }
                },
                {
                  "id": "timezone",
                  "type": "select",
                  "props": {
                    "label": "Timezone",
                    "options": ["UTC", "EST", "PST", "GMT"],
                    "value": "UTC"
                  }
                },
                {
                  "id": "preferences-panel",
                  "type": "panel",
                  "props": {
                    "title": "Preferences"
                  }
                },
                {
                  "id": "auto-save",
                  "type": "checkbox",
                  "props": {
                    "label": "Enable auto-save",
                    "checked": true
                  }
                },
                {
                  "id": "spell-check",
                  "type": "checkbox",
                  "props": {
                    "label": "Enable spell check",
                    "checked": false
                  }
                },
                {
                  "id": "analytics",
                  "type": "checkbox",
                  "props": {
                    "label": "Share analytics data",
                    "checked": true
                  }
                },
                {
                  "id": "save-settings-btn",
                  "type": "button",
                  "props": {
                    "label": "Save Settings",
                    "variant": "primary"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

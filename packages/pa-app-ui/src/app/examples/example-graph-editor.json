{
  "id": "graph-editor-example",
  "type": "app",
  "name": "Product Architect",
  "theme": "dark",
  "showModuleSidebar": false,
  "version": "1.0.0",
  "modules": [
    {
      "id": "editor",
      "type": "module",
      "name": "Graph Editor",
      "icon": "network",
      "showNavigation": false,
      "pages": [
        {
          "id": "canvas-page",
          "type": "page",
          "title": "Canvas",
          "showHeader": false,
          "sections": [
            {
              "id": "left-sidebar",
              "type": "section",
              "layout": "vertical",
              "blocks": [
                {
                  "id": "sidebar-title",
                  "type": "heading",
                  "props": {
                    "level": 3,
                    "text": "Tools"
                  }
                },
                {
                  "id": "tool-1",
                  "type": "button",
                  "props": {
                    "label": "Select",
                    "icon": "→",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "tool-2",
                  "type": "button",
                  "props": {
                    "label": "Pan",
                    "icon": "✋",
                    "variant": "ghost"
                  }
                },
                {
                  "id": "tool-3",
                  "type": "button",
                  "props": {
                    "label": "Connect",
                    "icon": "🔗",
                    "variant": "ghost"
                  }
                }
              ]
            },
            {
              "id": "canvas",
              "type": "section",
              "layout": "flex",
              "blocks": [
                {
                "id": "graph",
                "type": "graph-canvas",
                "props": {
                  "editable": true,
                  "zoom": true,
                  "pan": true,
                  "grid": true,
                  "snapToGrid": false
                }
              }
              ]
            },
            {
              "id": "right-sidebar",
              "type": "section",
              "layout": "vertical",
              "blocks": [
                {
                  "id": "inspector-title",
                  "type": "heading",
                  "props": {
                    "level": 3,
                    "text": "Inspector"
                  }
                },
                {
                  "id": "inspector-desc",
                  "type": "paragraph",
                  "props": {
                    "text": "Select a node to view its properties."
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dna.codes/schemas/api/api.json",
  "title": "API Layer",
  "description": "The API layer of an application containing endpoints, payloads, and authentication context.",
  "examples": [
    {
      "name": "Loan API Layer",
      "key": "loanApiLayer",
      "type": "API",
      "description": "RESTful API for loan application processing",
      "baseUrl": "https://api.example.com/v1/loans",
      "version": "1.0.0",
      "endpoints": [
        {
          "name": "Submit Loan Application",
          "key": "submitLoanApplication",
          "type": "Endpoint"
        }
      ],
      "authContext": {
        "name": "API Authentication Context",
        "key": "apiAuthContext",
        "type": "AuthContext"
      }
    }
  ],
  "allOf": [
    { "$ref": "https://dna.codes/schemas/base.json" },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "API"
        },
        "baseUrl": {
          "type": "string",
          "description": "Base URL for the API."
        },
        "version": {
          "type": "string",
          "description": "API version following semantic versioning."
        },
        "endpoints": {
          "type": "array",
          "description": "Endpoints available in this API layer.",
          "items": {
            "$ref": "https://dna.codes/schemas/application/api/endpoint.json"
          }
        },
        "authContext": {
          "type": "object",
          "description": "Authentication context for the API layer.",
          "$ref": "https://dna.codes/schemas/application/api/auth-context.json"
        }
      }
    }
  ]
}

// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`@dna-codes/output-openapi render() — bookshop fixture emits stable output for the bookshop fixture (snapshot) 1`] = `
"openapi: 3.1.0
info:
  title: Bookshop API
  version: 0.1.0
  description: Bookshop catalog and publishing endpoints.
tags:
- name: Bookshop
  description: Bookshop catalog and publishing endpoints.
paths:
  "/bookshop/books":
    get:
      operationId: bookList
      description: List books in the catalog.
      tags:
      - Bookshop
      parameters:
      - name: status
        in: query
        schema:
          type: string
          enum:
          - draft
          - live
          - retired
      - name: limit
        in: query
        description: Max rows returned (default 50).
        schema:
          type: number
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                "$ref": "#/components/schemas/BookListResponse"
  "/bookshop/books/{id}":
    get:
      operationId: bookGet
      description: Fetch a single book by ID.
      tags:
      - Bookshop
      parameters:
      - name: id
        in: path
        required: true
        schema:
          type: string
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                "$ref": "#/components/schemas/BookResponse"
  "/bookshop/books/{id}/publish":
    post:
      operationId: bookPublish
      description: Publish a draft book. Requires editorial approval per the PublishFlow Process.
      tags:
      - Bookshop
      parameters:
      - name: id
        in: path
        required: true
        schema:
          type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              "$ref": "#/components/schemas/PublishBookRequest"
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                "$ref": "#/components/schemas/BookResponse"
components:
  schemas:
    BookListResponse:
      type: object
      description: A page of books.
      properties:
        items:
          type: string
          description: "BookSummary[] (see components)."
        total:
          type: number
      required:
      - items
      - total
    BookResponse:
      type: object
      description: A single book.
      properties:
        id:
          type: string
        title:
          type: string
        price:
          type: number
        status:
          type: string
          enum:
          - draft
          - live
          - retired
      required:
      - id
      - title
      - price
      - status
    PublishBookRequest:
      type: object
      properties:
        note:
          type: string
          description: Optional editorial note.
"
`;

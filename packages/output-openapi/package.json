{
  "name": "@dna-codes/dna-output-openapi",
  "version": "0.4.0",
  "repository": "github:dna-codes/dna",
  "description": "Render a DNA Product API document as an OpenAPI 3.1 specification (YAML or JSON). The contract layer between DNA's product layer and any technical implementation. Zero runtime dependencies.",
  "keywords": ["dna", "openapi", "output-openapi", "contract", "api"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@dna-codes/dna-core": "^0.4.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "js-yaml": "^4.1.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dna.codes/schemas/technical/cell",
  "title": "Cell",
  "description": "A Cell is a deployed unit: DNA + Adapter + wired Constructs. It is the concrete embodiment of cell-based architecture — it accepts a DNA document, applies an adapter, and produces running software or infrastructure.",
  "type": "object",
  "required": ["name", "dna", "adapter"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The kebab-case name of the cell.",
      "examples": ["api", "ui", "db", "auth", "worker"]
    },
    "dna": {
      "type": "string",
      "description": "The path or identifier of the DNA document this cell consumes.",
      "examples": ["product/api", "product/ui", "operational/loan"]
    },
    "adapter": {
      "type": "object",
      "description": "The framework/runtime adapter that interprets the DNA.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "The adapter type.",
          "examples": ["nestjs", "express", "nextjs", "nuxt", "rails", "django", "postgres", "redis", "auth0"]
        },
        "version": {
          "type": "string",
          "description": "The adapter version.",
          "examples": ["10", "4", "14", "7.1"]
        },
        "config": {
          "type": "object",
          "description": "Adapter-specific configuration.",
          "additionalProperties": true
        }
      }
    },
    "constructs": {
      "type": "array",
      "description": "The Construct names this cell uses.",
      "items": { "type": "string" },
      "examples": [["primary-db", "auth-provider"], ["api-gateway", "api-server"]]
    },
    "variables": {
      "type": "array",
      "description": "Variables injected into this cell at runtime.",
      "items": { "$ref": "https://dna.codes/schemas/technical/variable" }
    },
    "outputs": {
      "type": "array",
      "description": "Values this cell exports for other cells to reference.",
      "items": { "$ref": "https://dna.codes/schemas/technical/output" }
    },
    "environment": {
      "type": "string",
      "description": "If set, this cell definition is scoped to a specific Environment.",
      "examples": ["dev", "staging", "prod"]
    },
    "description": {
      "type": "string",
      "description": "A human-readable explanation of what this cell does."
    }
  },
  "examples": [
    {
      "name": "api",
      "dna": "product/api",
      "adapter": { "type": "nestjs", "version": "10" },
      "constructs": ["primary-db", "auth-provider"],
      "outputs": [{ "name": "api.url", "cell": "api", "value": "api-gateway.url" }]
    },
    {
      "name": "db",
      "dna": "operational/loan",
      "adapter": { "type": "postgres", "version": "15" },
      "constructs": ["primary-db"]
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dna.codes/schemas/technical/construct",
  "title": "Construct",
  "description": "A Construct is a named infrastructure component with a category and type. Constructs are declared once and referenced by multiple Cells.",
  "type": "object",
  "required": ["name", "category", "type"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The kebab-case name of the construct, used as a reference key.",
      "examples": ["primary-db", "auth-provider", "file-store", "api-gateway"]
    },
    "category": {
      "type": "string",
      "description": "The infrastructure category of the construct.",
      "enum": ["compute", "storage", "network"]
    },
    "type": {
      "type": "string",
      "description": "The specific type within the category.",
      "enum": [
        "function", "container", "server", "worker",
        "database", "cache", "filestore", "queue",
        "gateway", "loadbalancer", "cdn"
      ]
    },
    "description": {
      "type": "string",
      "description": "A human-readable explanation of what this construct represents."
    },
    "provider": {
      "type": "string",
      "description": "The Provider name that backs this construct.",
      "examples": ["aws", "gcp", "planetscale", "upstash"]
    },
    "environment": {
      "type": "string",
      "description": "If set, this construct is scoped to a specific Environment.",
      "examples": ["dev", "staging", "prod"]
    },
    "config": {
      "type": "object",
      "description": "Provider-specific configuration for this construct.",
      "additionalProperties": true
    }
  },
  "if": {
    "properties": { "category": { "const": "compute" } },
    "required": ["category"]
  },
  "then": {
    "properties": {
      "type": { "enum": ["function", "container", "server", "worker"] }
    }
  },
  "examples": [
    { "name": "primary-db", "category": "storage", "type": "database", "provider": "aws", "config": { "engine": "postgres", "version": "15" } },
    { "name": "api-gateway", "category": "network", "type": "gateway", "provider": "aws" },
    { "name": "api-server", "category": "compute", "type": "container", "provider": "aws", "config": { "cpu": 256, "memory": 512 } }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dna.codes/schemas/api/auth-context.json",
  "title": "Auth Context Schema",
  "description": "Defines authentication context — the actor and permissions for API operations.",
  "examples": [
    {
      "name": "API Authentication Context",
      "key": "apiAuthContext",
      "type": "AuthContext",
      "description": "Authentication and authorization configuration for API operations",
      "actor": {
        "name": "User",
        "key": "user",
        "type": "Actor::User"
      },
      "authMethods": [
        {
          "name": "Bearer Token",
          "key": "bearerToken",
          "type": "AuthMethod",
          "scheme": "Bearer",
          "description": "JWT bearer token authentication"
        },
        {
          "name": "API Key",
          "key": "apiKey",
          "type": "AuthMethod",
          "scheme": "ApiKey",
          "description": "API key authentication for service accounts"
        }
      ],
      "permissions": [
        {
          "name": "Read Own Loans",
          "key": "readOwnLoans",
          "type": "Permission",
          "resource": "loan",
          "action": "read",
          "scope": "self"
        },
        {
          "name": "Submit Loan Application",
          "key": "submitLoanApplication",
          "type": "Permission",
          "resource": "loan",
          "action": "create",
          "scope": "self"
        }
      ],
      "roles": [
        {
          "name": "Borrower",
          "key": "borrower",
          "type": "Role",
          "permissions": ["readOwnLoans", "submitLoanApplication"]
        },
        {
          "name": "Loan Officer",
          "key": "loanOfficer",
          "type": "Role",
          "permissions": ["readAllLoans", "reviewApplications", "approveLoan", "rejectLoan"]
        }
      ]
    }
  ],
  "allOf": [
    { "$ref": "https://dna.codes/schemas/base.json" },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "AuthContext"
        },
        "actor": {
          "type": "object",
          "description": "The actor (user, role, system, or agent) performing API operations.",
          "$ref": "https://dna.codes/schemas/core/actor.json"
        },
        "authMethods": {
          "type": "array",
          "description": "Supported authentication methods.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "key": { "type": "string" },
              "type": { "type": "string" },
              "scheme": {
                "type": "string",
                "enum": ["Bearer", "Basic", "ApiKey", "OAuth2", "SAML", "OIDC"]
              },
              "description": { "type": "string" }
            },
            "required": ["id", "name", "key", "type", "scheme"]
          }
        },
        "permissions": {
          "type": "array",
          "description": "Granular permissions available in this auth context.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "key": { "type": "string" },
              "type": { "type": "string" },
              "resource": { "type": "string", "description": "Resource this permission applies to." },
              "action": { "type": "string", "description": "Action allowed (read, create, update, delete)." },
              "scope": { "type": "string", "description": "Scope of permission (self, team, organization, all)." },
              "conditions": { "type": "object", "description": "Optional conditions for permission grant." }
            },
            "required": ["id", "name", "key", "type", "resource", "action"]
          }
        },
        "roles": {
          "type": "array",
          "description": "Roles that bundle permissions together.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "key": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" },
              "permissions": {
                "type": "array",
                "description": "Permission keys included in this role.",
                "items": { "type": "string" }
              }
            },
            "required": ["id", "name", "key", "type"]
          }
        }
      }
    }
  ]
}

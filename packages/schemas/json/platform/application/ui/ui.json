{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dna.codes/schemas/ui/ui.json",
  "title": "UI Layer Schema",
  "description": "Defines the user interface layer of an application containing pages, components, and flows.",
  "examples": [
    {
      "id": "loan-ui-layer",
      "name": "Loan UI Layer",
      "key": "loanUiLayer",
      "type": "UI",
      "description": "Comprehensive user interface for loan application management including multi-step flows, dashboard views, and interactive components",
      "pages": [
        {
          "id": "loan-dashboard-page",
          "name": "Loan Dashboard",
          "key": "loanDashboard",
          "type": "Page",
          "description": "Main dashboard for viewing loan application status and details",
          "resourceId": "loan-app-12345",
          "resourceName": "Personal Loan Application",
          "layout": {
            "id": "loan-dashboard-layout",
            "name": "Loan Dashboard Layout",
            "key": "loanDashboardLayout",
            "type": "Layout",
            "structure": "grid",
            "gridColumns": 12,
            "containers": [
              {
                "id": "header-container",
                "name": "Header",
                "key": "header",
                "type": "Container",
                "position": {
                  "row": 1,
                  "column": 1,
                  "columnSpan": 12,
                  "rowSpan": 1
                },
                "height": "auto",
                "components": [
                  {
                    "componentId": "app-header-component",
                    "componentName": "App Header",
                    "order": 1
                  }
                ]
              },
              {
                "id": "main-content-container",
                "name": "Main Content",
                "key": "mainContent",
                "type": "Container",
                "position": {
                  "row": 2,
                  "column": 1,
                  "columnSpan": 12,
                  "rowSpan": 1
                },
                "padding": "24px",
                "components": [
                  {
                    "componentId": "application-details-component",
                    "componentName": "Application Details",
                    "order": 1
                  },
                  {
                    "componentId": "loan-status-component",
                    "componentName": "Loan Status",
                    "order": 2
                  },
                  {
                    "componentId": "action-buttons-component",
                    "componentName": "Action Buttons",
                    "order": 3
                  }
                ]
              }
            ]
          },
          "sections": [
            {
              "id": "application-details-section",
              "containerId": "main-content-container",
              "type": "Section",
              "attributes": ["loanAmount", "loanPurpose", "status"]
            }
          ],
          "actions": [
            {
              "id": "submit-application",
              "name": "Submit Application",
              "key": "submitApplication",
              "type": "PageAction"
            },
            {
              "id": "edit-application",
              "name": "Edit Application",
              "key": "editApplication",
              "type": "PageAction"
            }
          ]
        },
        {
          "id": "borrower-info-page",
          "name": "Borrower Information",
          "key": "borrowerInfo",
          "type": "Page",
          "description": "Page for collecting borrower personal and employment information",
          "resourceId": "borrower-12345",
          "resourceName": "Borrower Profile",
          "layout": {
            "id": "borrower-info-layout",
            "name": "Borrower Information Layout",
            "key": "borrowerInfoLayout",
            "type": "Layout",
            "structure": "flexbox",
            "containers": [
              {
                "id": "form-container",
                "name": "Form",
                "key": "form",
                "type": "Container",
                "position": {
                  "row": 1,
                  "column": 1,
                  "columnSpan": 12
                },
                "padding": "24px",
                "components": [
                  {
                    "componentId": "borrower-form-component",
                    "componentName": "Borrower Form",
                    "order": 1
                  }
                ]
              }
            ]
          },
          "sections": [
            {
              "id": "borrower-details-section",
              "containerId": "form-container",
              "type": "Section",
              "attributes": ["firstName", "lastName", "email", "phone"]
            }
          ]
        },
        {
          "id": "loan-details-page",
          "name": "Loan Details",
          "key": "loanDetails",
          "type": "Page",
          "description": "Page for specifying loan amount, purpose, and term",
          "resourceId": "loan-details-12345",
          "resourceName": "Loan Details Form",
          "layout": {
            "id": "loan-details-layout",
            "name": "Loan Details Layout",
            "key": "loanDetailsLayout",
            "type": "Layout",
            "structure": "flexbox",
            "containers": [
              {
                "id": "loan-form-container",
                "name": "Loan Form",
                "key": "loanForm",
                "type": "Container",
                "position": {
                  "row": 1,
                  "column": 1,
                  "columnSpan": 12
                },
                "padding": "24px",
                "components": [
                  {
                    "componentId": "loan-form-component",
                    "componentName": "Loan Form",
                    "order": 1
                  }
                ]
              }
            ]
          },
          "sections": [
            {
              "id": "loan-form-section",
              "containerId": "loan-form-container",
              "type": "Section",
              "attributes": ["loanAmount", "loanPurpose", "loanTerm"]
            }
          ]
        },
        {
          "id": "review-page",
          "name": "Review & Submit",
          "key": "review",
          "type": "Page",
          "description": "Review page for confirming all application details before submission",
          "resourceId": "review-12345",
          "resourceName": "Application Review",
          "layout": {
            "id": "review-layout",
            "name": "Review Layout",
            "key": "reviewLayout",
            "type": "Layout",
            "structure": "flexbox",
            "containers": [
              {
                "id": "review-container",
                "name": "Review",
                "key": "review",
                "type": "Container",
                "position": {
                  "row": 1,
                  "column": 1,
                  "columnSpan": 12
                },
                "padding": "24px",
                "components": [
                  {
                    "componentId": "review-component",
                    "componentName": "Review Component",
                    "order": 1
                  }
                ]
              }
            ]
          },
          "sections": [
            {
              "id": "review-summary-section",
              "containerId": "review-container",
              "type": "Section",
              "attributes": ["borrowerName", "email", "loanAmount", "loanPurpose", "loanTerm"]
            }
          ]
        },
        {
          "id": "confirmation-page",
          "name": "Confirmation",
          "key": "confirmation",
          "type": "Page",
          "description": "Confirmation page displayed after successful application submission",
          "layout": {
            "id": "confirmation-layout",
            "name": "Confirmation Layout",
            "key": "confirmationLayout",
            "type": "Layout",
            "structure": "flexbox",
            "containers": [
              {
                "id": "confirmation-container",
                "name": "Confirmation",
                "key": "confirmation",
                "type": "Container",
                "position": {
                  "row": 1,
                  "column": 1,
                  "columnSpan": 12
                },
                "padding": "24px",
                "components": [
                  {
                    "componentId": "confirmation-component",
                    "componentName": "Confirmation Message",
                    "order": 1
                  }
                ]
              }
            ]
          }
        }
      ],
      "components": [
        {
          "id": "borrower-form-component",
          "name": "Borrower Form",
          "key": "borrowerForm",
          "type": "Component",
          "description": "Form component for collecting borrower personal information",
          "fields": [
            {
              "id": "first-name-field",
              "name": "First Name",
              "key": "firstName",
              "type": "Field",
              "dataType": "string",
              "required": true
            },
            {
              "id": "last-name-field",
              "name": "Last Name",
              "key": "lastName",
              "type": "Field",
              "dataType": "string",
              "required": true
            },
            {
              "id": "email-field",
              "name": "Email Address",
              "key": "email",
              "type": "Field",
              "dataType": "string",
              "required": true,
              "validation": {
                "format": "email"
              }
            },
            {
              "id": "phone-field",
              "name": "Phone Number",
              "key": "phone",
              "type": "Field",
              "dataType": "string",
              "required": true
            }
          ],
          "handlers": [
            {
              "id": "form-submit-handler",
              "name": "On Submit",
              "key": "onSubmit",
              "type": "EventHandler",
              "action": "submitBorrowerInfo",
              "validation": true
            }
          ]
        },
        {
          "id": "loan-form-component",
          "name": "Loan Form",
          "key": "loanForm",
          "type": "Component",
          "description": "Form component for specifying loan amount, purpose, and term",
          "fields": [
            {
              "id": "loan-amount-field",
              "name": "Loan Amount",
              "key": "loanAmount",
              "type": "Field",
              "dataType": "number",
              "required": true,
              "validation": {
                "minimum": 1000,
                "maximum": 500000
              }
            },
            {
              "id": "loan-purpose-field",
              "name": "Loan Purpose",
              "key": "loanPurpose",
              "type": "Field",
              "dataType": "string",
              "required": true,
              "validation": {
                "enum": ["home-improvement", "debt-consolidation", "auto-purchase", "education", "other"]
              }
            },
            {
              "id": "loan-term-field",
              "name": "Loan Term (months)",
              "key": "loanTerm",
              "type": "Field",
              "dataType": "integer",
              "required": true,
              "validation": {
                "enum": [12, 24, 36, 48, 60]
              }
            }
          ],
          "handlers": [
            {
              "id": "form-submit-handler",
              "name": "On Submit",
              "key": "onSubmit",
              "type": "EventHandler",
              "action": "submitLoanDetails",
              "validation": true
            }
          ]
        },
        {
          "id": "review-component",
          "name": "Review Component",
          "key": "review",
          "type": "Component",
          "description": "Component for displaying application summary and confirming submission",
          "fields": [
            {
              "id": "summary-field",
              "name": "Application Summary",
              "key": "summary",
              "type": "Field",
              "dataType": "object",
              "required": true
            }
          ],
          "handlers": [
            {
              "id": "submit-handler",
              "name": "On Submit",
              "key": "onSubmit",
              "type": "EventHandler",
              "action": "submitApplication",
              "validation": true
            },
            {
              "id": "edit-handler",
              "name": "On Edit",
              "key": "onEdit",
              "type": "EventHandler",
              "action": "goBackToEdit"
            }
          ]
        },
        {
          "id": "confirmation-component",
          "name": "Confirmation Message",
          "key": "confirmationMessage",
          "type": "Component",
          "description": "Component displaying submission confirmation and application reference number",
          "fields": [
            {
              "id": "reference-number-field",
              "name": "Application Reference Number",
              "key": "referenceNumber",
              "type": "Field",
              "dataType": "string",
              "required": true
            },
            {
              "id": "confirmation-message-field",
              "name": "Confirmation Message",
              "key": "message",
              "type": "Field",
              "dataType": "string",
              "required": true
            }
          ],
          "handlers": [
            {
              "id": "return-home-handler",
              "name": "On Return Home",
              "key": "onReturnHome",
              "type": "EventHandler",
              "action": "navigateToHome"
            }
          ]
        },
        {
          "id": "loan-status-component",
          "name": "Loan Status",
          "key": "loanStatus",
          "type": "Component",
          "description": "Component displaying current application status",
          "fields": [
            {
              "id": "status-field",
              "name": "Status",
              "key": "status",
              "type": "Field",
              "dataType": "string",
              "required": true,
              "validation": {
                "enum": ["pending", "in-review", "approved", "rejected", "expired"]
              }
            }
          ],
          "handlers": [
            {
              "id": "status-change-handler",
              "name": "On Status Change",
              "key": "onStatusChange",
              "type": "EventHandler",
              "action": "updateStatusDisplay"
            }
          ]
        },
        {
          "id": "application-details-component",
          "name": "Application Details",
          "key": "applicationDetails",
          "type": "Component",
          "description": "Component displaying full application details on dashboard",
          "fields": [
            {
              "id": "application-id-field",
              "name": "Application ID",
              "key": "applicationId",
              "type": "Field",
              "dataType": "string",
              "required": true
            },
            {
              "id": "submission-date-field",
              "name": "Submission Date",
              "key": "submissionDate",
              "type": "Field",
              "dataType": "string",
              "required": true
            }
          ]
        }
      ],
      "flows": [
        {
          "id": "application-submission-flow",
          "name": "Application Submission Flow",
          "key": "applicationSubmissionFlow",
          "type": "Flow",
          "description": "Step-by-step flow for submitting a complete loan application",
          "startStep": "borrower-info-step",
          "steps": [
            {
              "id": "borrower-info-step",
              "name": "Borrower Information",
              "key": "borrowerInfo",
              "type": "Step",
              "description": "Collect borrower personal information",
              "pageId": "borrower-info-page",
              "componentId": "borrower-form-component",
              "action": "collectBorrowerInfo",
              "nextStep": "loan-details-step"
            },
            {
              "id": "loan-details-step",
              "name": "Loan Details",
              "key": "loanDetails",
              "type": "Step",
              "description": "Collect loan specifications",
              "pageId": "loan-details-page",
              "componentId": "loan-form-component",
              "action": "collectLoanDetails",
              "nextStep": "review-step"
            },
            {
              "id": "review-step",
              "name": "Review & Submit",
              "key": "review",
              "type": "Step",
              "description": "Review all information before final submission",
              "pageId": "review-page",
              "componentId": "review-component",
              "action": "reviewApplication",
              "nextStep": "confirmation-step"
            },
            {
              "id": "confirmation-step",
              "name": "Confirmation",
              "key": "confirmation",
              "type": "Step",
              "description": "Display submission confirmation",
              "pageId": "confirmation-page",
              "componentId": "confirmation-component",
              "action": "displayConfirmation",
              "isEnd": true
            }
          ],
          "transitions": [
            {
              "from": "borrower-info-step",
              "to": "loan-details-step",
              "trigger": "formSubmitted",
              "condition": "borrowerInfoValid"
            },
            {
              "from": "loan-details-step",
              "to": "review-step",
              "trigger": "formSubmitted",
              "condition": "loanDetailsValid"
            },
            {
              "from": "review-step",
              "to": "confirmation-step",
              "trigger": "submitClicked",
              "condition": "allDataValid"
            },
            {
              "from": "review-step",
              "to": "loan-details-step",
              "trigger": "editClicked",
              "condition": null
            }
          ]
        }
      ]
    }
  ],
  "allOf": [
    { "$ref": "https://dna.codes/schemas/base.json" },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "UI"
        },
        "pages": {
          "type": "array",
          "description": "Pages in the UI layer (resource views).",
          "items": {
            "$ref": "https://dna.codes/schemas/application/ui/page.json"
          }
        },
        "components": {
          "type": "array",
          "description": "Components in the UI layer (action handlers).",
          "items": {
            "$ref": "https://dna.codes/schemas/application/ui/component.json"
          }
        },
        "flows": {
          "type": "array",
          "description": "Flows in the UI layer (sequences of actions).",
          "items": {
            "$ref": "https://dna.codes/schemas/application/ui/flow.json"
          }
        }
      }
    }
  ]
}

{
  "name": "@dna-codes/integration-jira",
  "version": "0.1.0",
  "description": "Bidirectional DNA integration for Jira Cloud. Pulls an Epic's description through @dna-codes/input-text into DNA, then pushes child Stories rendered by @dna-codes/output-text. Basic auth with email + API token.",
  "keywords": ["dna", "jira", "integration", "epic", "story"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "integration-jira": "./bin/integration-jira.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "dependencies": {
    "@dna-codes/input-text": "^0.3.0",
    "@dna-codes/output-text": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

{
  "name": "@dna-codes/dna-input-openapi",
  "version": "0.4.0",
  "description": "Parse an OpenAPI 3.x spec (already JSON-parsed) into a DNA Product API document — namespace, endpoints, and schemas. Zero runtime dependencies.",
  "keywords": ["dna", "openapi", "input-openapi", "api", "swagger"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "devDependencies": {
    "@dna-codes/dna-core": "^0.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

{
  "name": "@dna-codes/output-mermaid",
  "version": "0.1.0",
  "description": "Render DNA documents as Mermaid diagrams — ERDs from Resources + Relationships, flowcharts from Processes. Zero runtime dependencies.",
  "keywords": ["dna", "mermaid", "diagram", "erd", "flowchart", "output-mermaid"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest --passWithNoTests"
  },
  "devDependencies": {
    "@dna-codes/core": "^0.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

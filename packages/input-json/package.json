{
  "name": "@dna-codes/input-json",
  "version": "0.0.1",
  "description": "Infer a DNA operational slice from a plain JSON data sample — scalar fields become Attributes, nested objects become Resources + one-to-one Relationships, arrays of objects become Resources + one-to-many Relationships. Zero runtime dependencies.",
  "keywords": ["dna", "json", "input-json", "schema-inference", "resource"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "devDependencies": {
    "@dna-codes/core": "^0.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

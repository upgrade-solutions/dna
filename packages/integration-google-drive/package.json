{
  "name": "@dna-codes/dna-integration-google-drive",
  "version": "0.1.0",
  "repository": "github:dna-codes/dna",
  "description": "Stub Google Drive integration that satisfies the @dna-codes/dna-ingest Integration contract. Serves contents from an in-memory mock map; throws NotImplementedError for real Drive fetches. Real auth + Drive API ship in a follow-up change.",
  "keywords": ["dna", "integration", "google-drive", "stub"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "dependencies": {
    "@dna-codes/dna-ingest": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}

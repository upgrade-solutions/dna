{
  "domain": {
    "name": "marketplace",
    "path": "rentals.marketplace",
    "description": "Two-sided rental marketplace (Airbnb-style). The same Person template (Member) is eligible for peer Roles (Host, Guest) across distinct Group types (Listing, Booking) — captured by Memberships, not by per-instance bindings.",
    "resources": [],
    "persons": [
      {
        "name": "Member",
        "description": "Anyone on the platform. Person template — eligible for both Host and Guest Roles via Memberships. The same Member instance can simultaneously hold Host on one Listing and Guest on a Booking elsewhere; that simultaneity is runtime data.",
        "attributes": [
          { "name": "id",           "type": "string", "required": true },
          { "name": "display_name", "type": "string", "required": true },
          { "name": "email",        "type": "string" },
          { "name": "joined_at",    "type": "datetime" }
        ]
      },
      {
        "name": "PlatformStaff",
        "description": "Internal worker; eligible for the global SupportAgent Role."
      }
    ],
    "groups": [
      {
        "name": "Listing",
        "description": "A property for rent. Group that scopes the Host Role; also has its own lifecycle and attributes.",
        "attributes": [
          { "name": "id",            "type": "string", "required": true },
          { "name": "title",         "type": "string", "required": true },
          { "name": "host_id",       "type": "reference", "resource": "Member", "required": true },
          { "name": "status",        "type": "enum",   "required": true, "values": ["draft", "active", "paused", "delisted"] },
          { "name": "nightly_rate",  "type": "number", "required": true }
        ],
        "actions": [
          { "name": "Publish", "description": "Host publishes a draft listing.", "type": "write" },
          { "name": "Pause",   "type": "write" },
          { "name": "Delist",  "type": "destructive" }
        ]
      },
      {
        "name": "Booking",
        "description": "A reservation against a Listing for a Guest. Group that scopes the Guest Role; also has its own lifecycle.",
        "attributes": [
          { "name": "id",         "type": "string", "required": true },
          { "name": "listing_id", "type": "reference", "resource": "Listing", "required": true },
          { "name": "guest_id",   "type": "reference", "resource": "Member",  "required": true },
          { "name": "checkin",    "type": "date",   "required": true },
          { "name": "checkout",   "type": "date",   "required": true },
          { "name": "status",     "type": "enum",   "required": true, "values": ["requested", "approved", "declined", "cancelled", "completed"] }
        ],
        "actions": [
          { "name": "Request", "description": "Guest requests a booking.",          "type": "write" },
          { "name": "Approve", "description": "Host approves a pending booking.",   "type": "write" },
          { "name": "Decline", "type": "write" },
          { "name": "Cancel",  "type": "destructive" }
        ]
      }
    ],
    "roles": [
      { "name": "Host",         "description": "A Member who has published a Listing. Scoped to the Listing they own.", "scope": "Listing", "cardinality": "one", "required": true },
      { "name": "Guest",        "description": "A Member on a Booking they requested. Scoped to that Booking.",         "scope": "Booking", "cardinality": "one", "required": true },
      { "name": "SupportAgent", "description": "Platform staff handling disputes. Unscoped — global across all Listings and Bookings." }
    ]
  },
  "memberships": [
    { "name": "MemberHost",            "person": "Member",        "role": "Host",         "description": "Members may hold the Host role on Listings they own." },
    { "name": "MemberGuest",           "person": "Member",        "role": "Guest",        "description": "Members may hold the Guest role on Bookings they place." },
    { "name": "PlatformStaffSupport",  "person": "PlatformStaff", "role": "SupportAgent", "description": "Platform staff may hold the global SupportAgent role." }
  ],
  "operations": [
    { "target": "Listing", "action": "Publish", "name": "Listing.Publish" },
    { "target": "Listing", "action": "Pause",   "name": "Listing.Pause" },
    { "target": "Listing", "action": "Delist",  "name": "Listing.Delist" },
    { "target": "Booking", "action": "Request", "name": "Booking.Request" },
    { "target": "Booking", "action": "Approve", "name": "Booking.Approve" },
    { "target": "Booking", "action": "Decline", "name": "Booking.Decline" },
    { "target": "Booking", "action": "Cancel",  "name": "Booking.Cancel" }
  ],
  "triggers": [
    { "operation": "Listing.Publish", "source": "user" },
    { "operation": "Booking.Request", "source": "user" },
    { "operation": "Booking.Approve", "source": "user" },
    { "process":   "BookingFlow",     "source": "operation", "after": "Booking.Request", "description": "Booking request kicks off the host-approval SOP." }
  ],
  "rules": [
    { "operation": "Listing.Publish", "type": "access", "allow": [{ "role": "Host", "ownership": true }] },
    { "operation": "Listing.Pause",   "type": "access", "allow": [{ "role": "Host", "ownership": true }, { "role": "SupportAgent" }] },
    { "operation": "Listing.Delist",  "type": "access", "allow": [{ "role": "Host", "ownership": true }, { "role": "SupportAgent" }] },
    { "operation": "Booking.Request", "type": "access", "allow": [{ "role": "Guest" }] },
    { "operation": "Booking.Approve", "type": "access", "allow": [{ "role": "Host", "ownership": true }] },
    { "operation": "Booking.Decline", "type": "access", "allow": [{ "role": "Host", "ownership": true }] },
    { "operation": "Booking.Cancel",  "type": "access", "allow": [{ "role": "Guest", "ownership": true }, { "role": "Host", "ownership": true }, { "role": "SupportAgent" }] },
    {
      "name": "ListingIsActive",
      "operation": "Booking.Request",
      "type": "condition",
      "conditions": [{ "attribute": "listing.status", "operator": "eq", "value": "active" }]
    },
    {
      "name": "BookingIsRequested",
      "operation": "Booking.Approve",
      "type": "condition",
      "conditions": [{ "attribute": "booking.status", "operator": "eq", "value": "requested" }]
    }
  ],
  "outcomes": [
    { "operation": "Listing.Publish", "changes": [{ "attribute": "listing.status", "set": "active" }] },
    { "operation": "Listing.Pause",   "changes": [{ "attribute": "listing.status", "set": "paused" }] },
    { "operation": "Listing.Delist",  "changes": [{ "attribute": "listing.status", "set": "delisted" }] },
    { "operation": "Booking.Request", "changes": [{ "attribute": "booking.status", "set": "requested" }] },
    {
      "operation": "Booking.Approve",
      "changes": [{ "attribute": "booking.status", "set": "approved" }]
    },
    { "operation": "Booking.Decline", "changes": [{ "attribute": "booking.status", "set": "declined" }] },
    { "operation": "Booking.Cancel",  "changes": [{ "attribute": "booking.status", "set": "cancelled" }] }
  ],
  "relationships": [
    { "name": "Listing.host",     "from": "Listing", "to": "Member",  "cardinality": "many-to-one", "attribute": "host_id",    "inverse": "listings" },
    { "name": "Booking.listing",  "from": "Booking", "to": "Listing", "cardinality": "many-to-one", "attribute": "listing_id" },
    { "name": "Booking.guest",    "from": "Booking", "to": "Member",  "cardinality": "many-to-one", "attribute": "guest_id",   "inverse": "bookings" }
  ],
  "tasks": [
    { "name": "request-booking", "actor": "Guest", "operation": "Booking.Request" },
    { "name": "approve-booking", "actor": "Host",  "operation": "Booking.Approve" },
    { "name": "decline-booking", "actor": "Host",  "operation": "Booking.Decline" }
  ],
  "processes": [
    {
      "name": "BookingFlow",
      "description": "From a Guest's request through Host's approve-or-decline decision.",
      "operator": "SupportAgent",
      "startStep": "request",
      "steps": [
        { "id": "request", "task": "request-booking", "conditions": ["ListingIsActive"], "else": "abort" },
        { "id": "approve", "task": "approve-booking", "depends_on": ["request"], "conditions": ["BookingIsRequested"], "else": "decline" },
        { "id": "decline", "task": "decline-booking", "depends_on": ["request"] }
      ]
    }
  ]
}
